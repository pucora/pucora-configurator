FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /pucora-config-api ./cmd/pucora-config-api

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /pucora-config-api /usr/local/bin/pucora-config-api
EXPOSE 8081
ENV PORT=8081
CMD ["pucora-config-api"]
